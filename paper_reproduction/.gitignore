# Everything in this folder needed to reproduce the manuscript's results is
# source: the notebooks/scripts and the raw inputs in data/. Everything
# below is generated by running them (see README.md) and is intentionally
# not tracked -- only the empty-directory placeholders are.

systems/*
!systems/.gitkeep

output/figs/*
!output/figs/.gitkeep
output/tables/*
!output/tables/.gitkeep

# Superseded/stale files kept locally for reference, not needed to
# reproduce anything (see the "Archive / housekeeping" section of README.md).
archive/

__pycache__/
